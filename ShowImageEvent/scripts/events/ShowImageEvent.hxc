class ShowImageModule extends Module
{
      var activeImages:Array<FunkinSprite> = [];
      var activeTimers:Array<FlxTimer> = [];

      public function new()
      {
          super('ShowImageModule');
      }

      public override function onSongLoaded(event)
      {
          super.onSongLoaded(event);
          activeImages = [];
          activeTimers = [];
          for (theEvent in event.events)  
          {  
              if (theEvent.eventKind == "ShowImageEvent")  
              {  
                  FunkinMemory.cacheTexture(Paths.image(theEvent.getString('image')));
                  trace('Cached Image:${theEvent.getString('image')}.png');
              }
          } 
      }

      public function showImage(options:ShowImageOptions)
      {
        var img = new FunkinSprite(0, 0, Paths.image(options.imageName));
        img.zIndex = options.zindex;
        img.cameras = (options.cam == "hud") ? [PlayState.instance.camHUD] : [PlayState.instance.camGame];
        img.scrollFactor.set(options.scroll, options.scroll);
        img.scale.set(options.scale, options.scale);
        activeImages.push(img);

        var startPos = getPos(img, options.from, options.x, options.y);
        img.x = startPos.x;
        img.y = startPos.y;

        if (options.cam == "stage" && PlayState.instance.currentStage != null) {
            PlayState.instance.currentStage.add(img);
            PlayState.instance.currentStage.refresh();
        } else {
            PlayState.instance.add(img);
            PlayState.instance.refresh();
        }

        if (options.fade == "in" || options.fade == "inout") {
            img.alpha = 0;
            FlxTween.tween(img, {alpha: 1}, options.fadeTime);
        }

        if (options.shake == "in" || options.shake == "inout") {
            FlxTween.shake(img, options.shakeIntensity, options.shakeTime, FlxAxes.fromString(options.shakeAxes));
        }

        var toPos = getPos(img, options.to, options.x, options.y);
        if (options.easeIn == 'INSTANT') {
            img.x = toPos.x;
            img.y = toPos.y;
        } else {
            var durIn = Conductor.instance.stepLengthMs * options.duration / 1000;
            var easeInFunc = Reflect.field(FlxEase, options.easeIn);
            if (easeInFunc != null) FlxTween.tween(img, {x: toPos.x, y: toPos.y}, durIn, {ease: easeInFunc});
        }

        var tmr = new FlxTimer();
        activeTimers.push(tmr);

        tmr.start(options.stay, (t) -> {
            if (options.shake == "out" || options.shake == "inout") 
                FlxTween.shake(img, options.shakeIntensity, options.shakeTime, FlxAxes.fromString(options.shakeAxes),{onComplete: function(twn:FlxTween) { 
                if (options.easeOut == "INSTANT") localDestroy(img, tmr);
                }});

            if (options.fade == "out" || options.fade == "inout") 
                FlxTween.tween(img, {alpha: 0}, options.fadeTime, {onComplete: function(twn:FlxTween) { 
                if (options.easeOut == "INSTANT") localDestroy(img, tmr);
                }});

            if (options.easeOut == 'INSTANT') {
                if ((options.fade == "none" || options.fade == "in") && (options.shake == "in" || options.shake == "none")) 
                localDestroy(img, tmr);
            } else {
                var durOut = Conductor.instance.stepLengthMs * options.durationEnd / 1000;
                var easeOutFunc = Reflect.field(FlxEase, options.easeOut);
                var endPos = getPos(img, options.end, options.xEnd, options.yEnd);

                if (easeOutFunc != null)
                    FlxTween.tween(img, {x: endPos.x, y: endPos.y}, durOut, {ease: easeOutFunc, onComplete: (_) -> localDestroy(img, tmr)});
            }
        });
    }

    function localDestroy(?img:FunkinSprite, ?tmr:FlxTimer)
    {
        if (img != null) {
            activeImages.remove(img);
            img.destroy();
        }
        if (tmr != null) {
            activeTimers.remove(tmr);
            tmr.destroy();
        }
    }

    private function getPos(spr:FunkinSprite, type:String, targetX:Float, targetY:Float):{x:Float, y:Float} 
    {
        var res = {x: targetX, y: targetY};
        var w = spr.width;
        var h = spr.height;
        switch(type) {
            case "up":       res.x = (FlxG.width - w) / 2; res.y = -FlxG.height;
            case "upxy":     res.x = (FlxG.width - w) / 2 + targetX; res.y = -FlxG.height + targetY;
            case "down":     res.x = (FlxG.width - w) / 2; res.y = FlxG.height;
            case "downxy":   res.x = (FlxG.width - w) / 2 + targetX; res.y = FlxG.height + targetY;
            case "left":     res.x = -FlxG.width; res.y = (FlxG.height - h) / 2;
            case "leftxy":   res.x = -FlxG.width + targetX; res.y = (FlxG.height - h) / 2 + targetY;
            case "right":    res.x = FlxG.width; res.y = (FlxG.height - h) / 2;
            case "rightxy":  res.x = FlxG.width + targetX; res.y = (FlxG.height - h) / 2 + targetY;
            case "center":   res.x = (FlxG.width - w) / 2; res.y = (FlxG.height - h) / 2;
            case "centerxy": res.x = (FlxG.width - w) / 2 + targetX; res.y = (FlxG.height - h) / 2 + targetY;
            case "xy":       res.x = targetX; res.y = targetY;
            default:         res.x = targetX; res.y = targetY;
        }
        return res;
    }

    public override function onSongRetry(event)
    {
      super.onSongRetry(event);
      for (img in activeImages) if (img != null) localDestroy(img);
      for (tmr in activeTimers) if (tmr != null) localDestroy(null,tmr);
    }

    public override function onPause(event)
    {
        super.onPause(event);
        for (img in activeImages) if (img != null) FlxTweenUtil.pauseTweensOf(img);
        for (tmr in activeTimers) if (tmr != null) tmr.active = false;
    }

    public override function onResume(event)
    {
        super.onResume(event);
        for (img in activeImages) if (img != null) FlxTweenUtil.resumeTweensOf(img);
        for (tmr in activeTimers) if (tmr != null) tmr.active = true;
    }

    var lastEventKind:String;
    public override function onUpdate(event)
    {
        super.onUpdate(event);
        if(EventToolsUtil.getDataBox() == null) return;
        if(lastEventKind != FlxG.state.eventKindToPlace)
        {
          lastEventKind = FlxG.state.eventKindToPlace;
          if(lastEventKind != "ShowImageEvent") return;
          addTooltips();
          for(frame in ["entry_movement_frame", "exit_movement_frame", "visual_effects_frame"]) EventToolsUtil.getField(frame)?.collapsed = true;
          var shake = EventToolsUtil.getField("shake")?.value?.value ?? EventToolsUtil.getField("ease")?.value;
          var fade = EventToolsUtil.getField("fade")?.value?.value ?? EventToolsUtil.getField("ease")?.value;
          var to = EventToolsUtil.getField("to")?.value?.value ?? EventToolsUtil.getField("to")?.value;
          var easeIn = EventToolsUtil.getField("easein")?.value?.value ?? EventToolsUtil.getField("easein")?.value;
          var end = EventToolsUtil.getField("end")?.value?.value ?? EventToolsUtil.getField("end")?.value;
          var easeOut = EventToolsUtil.getField("easeout")?.value?.value ?? EventToolsUtil.getField("easeout")?.value;
          
          if(!to?.endsWith("xy"))
          {
            EventToolsUtil.hideField("x");
            EventToolsUtil.hideField("y");
          }

          if(easeIn == "INSTANT")
          {
            EventToolsUtil.hideField("duration");
          }

          if(!end?.endsWith("xy"))
          {
            EventToolsUtil.hideField("xEnd");
            EventToolsUtil.hideField("yEnd");
          }

          if(easeOut == "INSTANT")
          {
            EventToolsUtil.hideField("durationEnd");
          }

          if(fade == "none")
          {
            EventToolsUtil.hideField("fadeTime");
          }

          if(shake == "none")
          {
            for(field in ["shakeIntensity", "shakeAxes", "shakeTime"]) EventToolsUtil.hideField(field);
          }
        }

        if(lastEventKind == "ShowImageEvent") {
          var shake = EventToolsUtil.getField("shake")?.value?.value ?? EventToolsUtil.getField("ease")?.value;
          var fade = EventToolsUtil.getField("fade")?.value?.value ?? EventToolsUtil.getField("ease")?.value;
          var to = EventToolsUtil.getField("to")?.value?.value ?? EventToolsUtil.getField("to")?.value;
          var easeIn = EventToolsUtil.getField("easein")?.value?.value ?? EventToolsUtil.getField("easein")?.value;
          var end = EventToolsUtil.getField("end")?.value?.value ?? EventToolsUtil.getField("end")?.value;
          var easeOut = EventToolsUtil.getField("easeout")?.value?.value ?? EventToolsUtil.getField("easeout")?.value;

          if(!to?.endsWith("xy"))
          {
            EventToolsUtil.hideField("x", true);
            EventToolsUtil.hideField("y");
          }
          else
          {
            EventToolsUtil.showField("x", true);
            EventToolsUtil.showField("y");
          }

          if(easeIn == "INSTANT")
          {
            EventToolsUtil.hideField("duration", true);
          }
          else
          {
            EventToolsUtil.showField("duration", true);
          }

          if(!end?.endsWith("xy"))
          {
            EventToolsUtil.hideField("xEnd", true);
            EventToolsUtil.hideField("yEnd");
          }
          else
          {
            EventToolsUtil.showField("xEnd", true);
            EventToolsUtil.showField("yEnd");
          }

          if(easeOut == "INSTANT")
          {
            EventToolsUtil.hideField("durationEnd", true);
          }
          else
          {
            EventToolsUtil.showField("durationEnd", true);
          }

          if(fade == "none")
          {
            EventToolsUtil.hideField("fadeTime", true);
          }
          else
          {
            EventToolsUtil.showField("fadeTime", true);
          }

          if(shake == "none")
          {
            for(field in ["shakeIntensity", "shakeAxes", "shakeTime"]) EventToolsUtil.hideField(field, !EventToolsUtil.getField("shakeIntensity")?.hidden);
          }
          else
          {
            for(field in ["shakeIntensity", "shakeAxes", "shakeTime"]) EventToolsUtil.showField(field, !EventToolsUtil.getField("shakeIntensity")?.hidden);
          }
        }
    }

    private function addTooltips()
    {
        EventToolsUtil.addTooltip("image", "The path and file name of the image asset to load.");
        EventToolsUtil.addTooltip("stay", "How many seconds the image remains fully visible on screen.");
        EventToolsUtil.addTooltip("zindex", "The sorting layer order (higher numbers render on top).");
        EventToolsUtil.addTooltip("cam", "The camera layer to display the image on.");
        EventToolsUtil.addTooltip("scale", "The scale multiplier of the image asset.");
        EventToolsUtil.addTooltip("scroll", "How much the image position shifts along with the camera movement.");
        EventToolsUtil.addTooltip("from", "The starting position where the image spawns.");
        EventToolsUtil.addTooltip("to", "The destination where the image rests during its stay time.");
        EventToolsUtil.addTooltip("duration", "The animation travel time from Start to Final position (measured in steps).");
        EventToolsUtil.addTooltip("end", "The target position where the image moves when exiting.");
        EventToolsUtil.addTooltip("durationEnd", "The animation travel time from Final to End position (measured in steps).");
        EventToolsUtil.addTooltip("fade", "Apply an opacity fade style over the image transition.");
        EventToolsUtil.addTooltip("fadeTime", "The duration of the fade effect in seconds.");
        EventToolsUtil.addTooltip("shake", "Apply a vibration/shake effect directly to the image asset.");
        EventToolsUtil.addTooltip("shakeIntensity", "The pixel offset intensity or roughness of the image vibration.");
        EventToolsUtil.addTooltip("shakeAxes", "Select the direction for the image to shake (Horizontal, Vertical, or Both).");
        EventToolsUtil.addTooltip("shakeTime", "The total duration of the image shake effect in seconds.");
    }

    public override function onStateChangeBegin(event)
    {
        super.onStateChangeBegin(event);
        lastEventKind = null;
        activeImages = [];
        activeTimers = [];
    }
}

typedef ShowImageOptions = {
  imageName:String,
  stay:Float,
  zindex:Int,
  cam:String,
  scroll:Float,
  scale:Float,
  from:String,
  to:String,
  end:String,
  easeIn:String,
  easeOut:String,
  duration:Float,
  durationEnd:Float,
  x:Float,
  y:Float,
  xEnd:Float,
  yEnd:Float,
  fade:String,
  fadeTime:Float,
  shake:String,
  shakeAxes:String,
  shakeIntensity:Float,
  shakeTime:Float,
}