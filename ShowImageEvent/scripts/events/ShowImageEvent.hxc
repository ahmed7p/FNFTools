class ShowImageEvent extends SongEvent {

    public function new() {
        super("ShowImageEvent");
    }

    public override function handleEvent(data:SongEventData) {
     var imageName = (data.getString("image") != null) ? data.getString("image"):"GGMU";
     var stay = ( data.getFloat("stay") != null) ? data.getInt("stay"):1;
     var zindex = ( data.getInt("zindex") != null) ? data.getFloat("zindex"):1000;
     var cam = (data.getString("cam") != null) ? data.getString("cam"):"center";
     var scale = ( data.getFloat("scale") != null) ? data.getFloat("scale"):0;
     var scroll = ( data.getFloat("scroll") != null) ? data.getFloat("scroll"):0;
     var from = (data.getString("from") != null) ? data.getString("from"):"center";
     var to = (data.getString("to") != null) ? data.getString("to"):"xy";
     var end = (data.getString("end") != null) ? data.getString("end"):"xy";
     var easeIn = (data.getString("easein") != null) ? data.getString("easein"):"linear";
     var easeOut = (data.getString("easeout") != null) ? data.getString("easeout"):"linear";
     var duration = ( data.getFloat("duration") != null) ? data.getFloat("duration"):1;
     var durationEnd = ( data.getFloat("durationEnd") != null) ? data.getFloat("durationEnd"):1;
     var x = ( data.getFloat("x") != null) ? data.getFloat("x"):0;
     var y = ( data.getFloat("y") != null) ? data.getFloat("y"):0;
     var xEnd = ( data.getFloat("xEnd") != null) ? data.getFloat("xEnd"):0;
     var yEnd = ( data.getFloat("yEnd") != null) ? data.getFloat("yEnd"):0;
     var fade = (data.getString("fade") != null) ? data.getString("fade"):"none";
     var fadeTime = ( data.getFloat("fadeTime") != null) ? data.getFloat("fadeTime"):0.5;
     var shake = (data.getString("shake") != null) ? data.getString("shake"):"none";
     var shakeAxes = (data.getString("shakeAxes") != null) ? data.getString("shakeAxes"):"x";
     var shakeTime = ( data.getFloat("shakeTime") != null) ? data.getFloat("shakeTime"):0.5;
     var shakeIntensity = ( data.getFloat("shakeIntensity") != null) ? data.getFloat("shakeIntensity"):1.0;
     ModuleHandler.getModule("ShowImageModule").showImage({
        imageName: imageName,
        stay: stay,
        zindex: zindex,
        cam: cam,
        scroll: scroll,
        scale: scale,
        from: from,
        to: to,
        end: end,
        easeIn: easeIn,
        easeOut: easeOut,
        duration: duration,
        durationEnd: durationEnd,
        x: x,
        y: y,
        xEnd: xEnd,
        yEnd: yEnd,
        fade: fade,
        fadeTime: fadeTime,
        shake: shake,
        shakeAxes: shakeAxes,
        shakeIntensity: shakeIntensity,
        shakeTime: shakeTime,
      });
    }

    public override function getTitle() {
        return "Show Image Event";
    }

    public override function getEventSchema() {
      return [
        {
            name: "basic_image_settings_frame",
            title: "Basic Image Settings",
            type: "frame",
            collapsible: true,
            children: [
                {
                    name: "image",
                    title: "Image Path/Name",
                    type: "string",
                    defaultValue: "Showimage/GGMU"
                },
                {
                    name: "stay",
